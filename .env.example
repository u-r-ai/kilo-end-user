# Environment Variables
# Copy this file to .env and fill in your values
# Kilo End-User — AI Software Builder

# --- Provider Configuration ---
# Uncomment and fill in the provider you want to use
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# --- External Service Credentials ---
# These are used by AI-generated applications that integrate
# with external services (Google Drive, Gmail, WhatsApp, etc.)

# Google Service Account (for Google Drive/Sheets access)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail App Password (for sending email from applications)
# GMAIL_APP_PASSWORD=

# WhatsApp API
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Payment Gateway — Midtrans
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=

# Payment Gateway — Xendit
# XENDIT_API_KEY=

# Twilio (SMS)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
